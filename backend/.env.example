# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=admis_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173
VITE_CANDIDATE_URL=http://localhost:3000

# Brevo (Email via SMTP)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=AdmisX

# OTP
OTP_EXPIRES_IN=5
OTP_RESEND_COOLDOWN=60

# Application Deadline (DD/MM/YYYY)
APPLICATION_START_DATE=02/07/2025
APPLICATION_END_DATE=12/07/2025


# Default Admin Account (used in seed)
ADMIN_EMAIL=admin@admisx.com
ADMIN_PASSWORD=thay_bang_password_that

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=he-thong-tuyen-sinh

# FPT eKYC / OCR (backend only; never expose these in frontend .env)
FPT_API_KEY=
FPT_IDR_ENDPOINT=https://api.fpt.ai/vision/idr/vnm/
FPT_FACE_MATCH_ENDPOINT=https://api.fpt.ai/dmp/checkface/v1/
FPT_EKYC_TIMEOUT_MS=15000
EKYC_FACE_SIMILARITY_THRESHOLD=80
